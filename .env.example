# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Profile cache ─────────────────────────────────────────────────────────────
# Base64-encoded profile.cache.json — generated by: python -m src.main --rebuild-profile
# Leave empty for local development (agent reads profile.cache.json from disk instead)
PROFILE_CACHE=

# ── Twilio ────────────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=        # Your Twilio phone number, e.g. +15551234567
ALERT_PHONE_NUMBER=        # Your personal number to receive alerts, e.g. +15559876543

# ── Adzuna ────────────────────────────────────────────────────────────────────
# Get from: https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── Wellfound ─────────────────────────────────────────────────────────────────
# Get from: https://wellfound.com/developers
WELLFOUND_API_KEY=

# ── SerpAPI (company discovery only) ─────────────────────────────────────────
# Used only to resolve unknown company career pages — not for job searching.
# Free tier: 100 searches/month. Get from: https://serpapi.com
SEARCH_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev): sqlite:///./internship_agent.db
# Postgres (Railway):  postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./internship_agent.db

# ── Scheduler ─────────────────────────────────────────────────────────────────
RUN_INTERVAL_MINUTES=30    # How often to poll all sources (default: 30)

# ── Notifications ─────────────────────────────────────────────────────────────
# If matches in one cycle >= BURST_THRESHOLD, send one batched SMS instead of N individual ones
BURST_THRESHOLD=5

# ── Model overrides (optional) ────────────────────────────────────────────────
# Defaults shown. Haiku for scoring (fast/cheap), Sonnet for resume extraction (accuracy).
CLAUDE_SCORING_MODEL=claude-haiku-4-5
CLAUDE_EXTRACTION_MODEL=claude-sonnet-4-6
